<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 30px; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-font-family: 'Segoe UI', sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    
    <Label text="Crear Cuenta" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Label text="Únete para poder realizar compras." style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
    
    <VBox spacing="5">
        <Label text="Nombre Completo:" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <TextField fx:id="txtNombre" promptText="Ej. Juan Pérez" style="-fx-padding: 8px; -fx-font-size: 14px; -fx-background-radius: 5px; -fx-border-color: #bdc3c7; -fx-border-radius: 5px;"/>
    </VBox>
    
    <VBox spacing="5">
        <Label text="Correo Electrónico:" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <TextField fx:id="txtEmail" promptText="ejemplo@correo.com" style="-fx-padding: 8px; -fx-font-size: 14px; -fx-background-radius: 5px; -fx-border-color: #bdc3c7; -fx-border-radius: 5px;"/>
        <Label fx:id="lblEmailError" text="Correo inválido" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" visible="false" managed="false"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Contraseña:" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <PasswordField fx:id="txtPassword" promptText="Mínimo 6 caracteres" style="-fx-padding: 8px; -fx-font-size: 14px; -fx-background-radius: 5px; -fx-border-color: #bdc3c7; -fx-border-radius: 5px;"/>
        <Label fx:id="lblPasswordError" text="Mínimo 6 caracteres" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" visible="false" managed="false"/>
    </VBox>

    <Label fx:id="lblMensajeGlobal" style="-fx-font-size: 14px; -fx-font-weight: bold;" visible="false" managed="false"/>

    <Button fx:id="btnRegistrar" text="Registrarse" style="-fx-font-weight: bold; -fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 10 20 10 20; -fx-background-radius: 5px; -fx-cursor: hand; -fx-font-size: 16px; -fx-pref-width: 250px;"/>
    
    <ProgressIndicator fx:id="progressIndicator" visible="false" managed="false" style="-fx-pref-width: 30px; -fx-pref-height: 30px;"/>

</VBox>
