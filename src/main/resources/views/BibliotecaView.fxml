<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" style="-fx-background-color: #f4f6f9; -fx-font-family: 'Segoe UI', sans-serif;">
    <top>
        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 20px;">
            <Label text="📚 MyLib - Biblioteca Virtual" style="-fx-font-size: 28px; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label text="Encuentra tus libros favoritos y descubre tendencias" style="-fx-font-size: 14px; -fx-text-fill: #bdc3c7;"/>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="15" style="-fx-padding: 20px;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🔍 Buscar:" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                <TextField fx:id="txtBusqueda" promptText="Escribe el título del libro..." style="-fx-pref-width: 400px; -fx-font-size: 14px; -fx-background-radius: 5px; -fx-border-radius: 5px; -fx-border-color: #bdc3c7; -fx-padding: 5px;" />
            </HBox>
            
            <Label text="Resultados de la búsqueda" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
            <ListView fx:id="listResultados" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 5px; -fx-border-radius: 5px; -fx-border-color: #ecf0f1;" />
            <Label fx:id="lblEstado" text="Listo" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
        </VBox>
    </center>
    
    <right>
        <VBox spacing="10" style="-fx-padding: 20px; -fx-background-color: #ecf0f1; -fx-pref-width: 300px;">
            <Label text="🔥 Tendencias" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
            <Label text="Los libros más consultados" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
            <ListView fx:id="listTendencias" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-border-color: transparent;" />
        </VBox>
    </right>
</BorderPane>
